# =============================================================================
# agent-skills — environment template
#
# Prefer running `./setup.init` from the `agent-skills` folder. It copies this
# template to `.env` in your workspace root and asks a few setup questions. You
# can still copy this file manually when you want full control.
#
# The defaults are safe for a first local bootstrap run, but real issue-aware or
# code-changing work needs accurate project and issue-system context. `.env` is
# gitignored. Skills load values from `.env` at runtime; never put secrets or
# company-specific values inside SKILL.md files.
#
# Required vs Optional is marked per variable. Each skill stops with a clear
# message if a required local file, variable, credential, or project mapping is
# missing for the requested task — see the per-skill SKILL.md.
# =============================================================================

# -----------------------------------------------------------------------------
# Local setup guardrails
# -----------------------------------------------------------------------------
# If `.env` itself is missing, skills should warn and stop before issue-aware,
# repository-changing, PR, or release work. Generic planning/review can continue
# only when the user supplies enough context directly.
#
# Jira-driven work requires usable Jira environment variables or a user-supplied
# ticket summary with acceptance criteria/comments. `.jira-config.yml` is
# optional because most Jira CLIs can read these environment variables directly.

# -----------------------------------------------------------------------------
# Organization context (safe local defaults)
# -----------------------------------------------------------------------------
ORG_NAME="Local Workspace"                    # Display name used in prompts and summaries
ORG_DOMAIN="localhost"                        # Email/identity domain, if relevant
WORKSPACE_ROOT="${WORKSPACE_ROOT:-$PWD}"      # Root directory containing all repos; source from workspace root

# -----------------------------------------------------------------------------
# Multi-project workspace (safe local default; customize for accuracy)
#
# A JSON array of every project (repo) in the workspace the agent should know
# about. Different stacks are fully supported — list as many entries as you
# need. The default maps the current workspace as one generic project so a user
# can start locally without editing. For real delivery work, replace it with the
# actual repositories and commands so the agent can build, test, review, and
# reason about risk accurately.
#
# Per-project keys:
#   name             short identifier
#   path             relative path under ${WORKSPACE_ROOT}
#   stack            java | typescript | python | go | mixed | other
#   base_branch      overrides ${GITHUB_DEFAULT_BRANCH} for this project
#   build            full build-and-test command
#   format           formatter command (run before commit)
#   runtime_version  (optional) e.g. "21" for Java, "20" for Node, "3.12" for Python
#   coverage_target  (optional) percentage; overrides ${COVERAGE_TARGET_PERCENT}
#   notes            (optional) free-text reminders ("multi-mandate", "shared lib", etc.)
# -----------------------------------------------------------------------------
PROJECTS_JSON='[
  {"name":"current-workspace", "path":".", "stack":"other", "base_branch":"main", "build":"", "format":"", "runtime_version":"", "notes":"Bootstrap default. Replace with real repo entries for implementation, review, or PR work."}
]'

# Example multi-project map to adapt when ready:
# PROJECTS_JSON='[
#   {"name":"example-api",    "path":"example-api",    "stack":"java",       "base_branch":"main", "build":"mvn clean verify",   "format":"mvn fmt:format && mvn fmt:check", "runtime_version":"21"},
#   {"name":"example-web",    "path":"example-web",    "stack":"typescript", "base_branch":"main", "build":"npm ci && npm test", "format":"npm run lint && npm run format:check", "runtime_version":"20"},
#   {"name":"example-worker", "path":"example-worker", "stack":"python",     "base_branch":"main", "build":"pytest",             "format":"ruff check . && ruff format --check .", "runtime_version":"3.12"}
# ]'

# -----------------------------------------------------------------------------
# Source control (required only for clone/push/PR workflows)
# -----------------------------------------------------------------------------
GITHUB_ORG=""                                  # GitHub organisation or user that owns the repos
GITHUB_DEFAULT_BRANCH="main"                   # Default base branch for new feature work
GIT_COMMIT_MSG_FORMAT="<TICKET> <Brief description>"   # Hint string only
GIT_BRANCH_NAME_FORMAT="feature/<TICKET>-<short-desc>" # Hint string only
GIT_MERGE_STRATEGY="squash"                    # squash | merge | rebase

# -----------------------------------------------------------------------------
# Jira (required only when Jira is the issue source)
# -----------------------------------------------------------------------------
JIRA_HOST=""
JIRA_AUTH_TYPE="bearer"                        # bearer | basic
JIRA_API_TOKEN=""                              # Bearer token or PAT
JIRA_LOGIN=""
JIRA_CONFIG_FILE="${WORKSPACE_ROOT}/.jira-config.yml"  # Generated from .jira-config.example.yml
# Comma-separated list of Jira project keys (used to recognise ticket keys in branch names / text)
JIRA_PROJECT_KEYS=""
# Regex to extract a ticket key from a branch name or arbitrary text
JIRA_KEY_REGEX="[A-Z][A-Z0-9_]+-[0-9]+"

# -----------------------------------------------------------------------------
# Confluence (OPTIONAL — only when tickets reference Confluence pages)
# -----------------------------------------------------------------------------
CONFLUENCE_HOST=""
CONFLUENCE_API_TOKEN=""
CONFLUENCE_LOGIN=""

# -----------------------------------------------------------------------------
# Issue Investigator (OPTIONAL cache settings)
# -----------------------------------------------------------------------------
ISSUE_INVESTIGATOR_CACHE_DIR="${WORKSPACE_ROOT}/.cache/issue-investigator"
ISSUE_INVESTIGATOR_CACHE_TTL_HOURS="24"

# -----------------------------------------------------------------------------
# Code Reviewer (safe defaults; customize if your host supports model routing)
# -----------------------------------------------------------------------------
CODE_REVIEWER_BLOCKING="false"                 # false (advisory) | true (block on blocker findings)

# Pick ONE model id understood by your inference endpoint.
# Examples (uncomment the one you want):
#   openai/gpt-4o                     # high quality, fast, broad context
#   openai/gpt-4o-mini                # cheaper, faster, lower quality
#   openai/gpt-4.1                    # if available on your endpoint
#   anthropic/claude-3-5-sonnet       # very strong reasoning + code review
#   anthropic/claude-opus-4           # top-tier reasoning, slower / pricier
#   anthropic/claude-haiku-4          # cheap and fast for inner-loop review
#   google/gemini-1.5-pro             # large context window
#   google/gemini-2.0-flash           # cheap and fast
#   meta/llama-3.1-70b-instruct       # open weights, self-hostable
#   mistral/mistral-large             # strong code performance
#   deepseek/deepseek-coder-v2        # code-specialised
CODE_REVIEWER_MODEL="default"

CODE_REVIEWER_MAX_FILES="80"                   # Warn if non-trivial files exceed this
CODE_REVIEWER_MAX_DIFF_CHARS="60000"           # Diff character budget sent to the model
CODE_REVIEWER_CACHE_DIR="${WORKSPACE_ROOT}/.cache/code-reviewer"
CODE_REVIEWER_CACHE_TTL_HOURS="24"             # Issue-context fetch cache TTL
# Severities to display: comma-separated subset of blocker,major,minor,nit
CODE_REVIEWER_SHOW_SEVERITIES="blocker,major,minor,nit"
# Inner-loop trigger: review only blocker/major after Implementation phase
CODE_REVIEWER_INNER_LOOP_SEVERITIES="blocker,major"

# -----------------------------------------------------------------------------
# Build / runtime tooling (OPTIONAL — used by software-engineer for hints)
# -----------------------------------------------------------------------------
JDK_MANAGER="jenv"                             # jenv | sdkman | none
NODE_MANAGER="nvm"                             # nvm | volta | none
PYTHON_MANAGER="pyenv"                         # pyenv | conda | none
DOCKER_REQUIRED="true"                         # true if Testcontainers/compose is common

# -----------------------------------------------------------------------------
# Cross-project / shared library detection (OPTIONAL)
# Comma-separated patterns. Used by code-reviewer to flag downstream impact.
# -----------------------------------------------------------------------------
SHARED_LIBRARY_NAMES="shared-core,shared-utils,auth-starter"
API_MODULE_PATTERNS="-api/,/api/"
SECURITY_CONFIG_PATTERNS="SecurityConfig,WebSecurity,securityFilterChain,OAuth,Keycloak"
MIGRATION_PATH_PATTERNS="db/changelog/,liquibase/,migrations/"

# -----------------------------------------------------------------------------
# Quality gates (OPTIONAL)
# -----------------------------------------------------------------------------
SONAR_HOST_URL=""
SONAR_TOKEN=""
COVERAGE_TARGET_PERCENT="80"

# -----------------------------------------------------------------------------
# Extra context URLs (OPTIONAL — free-form list of links agents may consult)
# JSON array of {name, url, description}
# -----------------------------------------------------------------------------
IMPORTANT_URLS_JSON='[
  {"name":"Engineering handbook","url":"https://docs.example.org/engineering","description":"House style and process"},
  {"name":"Runbook index","url":"https://docs.example.org/runbooks","description":"On-call runbooks"}
]'
