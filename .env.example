# =============================================================================
# agent-skills — environment template
#
# Prefer running `./setup.init` from the `agent-skills` folder. It copies this
# template to `.env` in your workspace root and asks a few setup questions. You
# can still copy this file manually when you want full control.
#
# The defaults are safe for a first local bootstrap run, but real issue-aware or
# code-changing work needs accurate project and issue-system context. `.env` is
# gitignored. Skills load values from `.env` at runtime; never put secrets or
# company-specific values inside SKILL.md files.
#
# Required vs Optional is marked per variable. Each skill stops with a clear
# message if a required local file, variable, credential, or project mapping is
# missing for the requested task — see the per-skill SKILL.md.
#
# -----------------------------------------------------------------------------
# IMPORTANT: anatomy of this file
# -----------------------------------------------------------------------------
# Setup-managed keys (org identity, workspace, projects, Jira, Confluence,
# SonarQube, environment access pointers) live INSIDE the
# `# >>> agent-skills setup.init` ... `# <<< agent-skills setup.init` block.
# The block is owned by `./setup.init` and is overwritten on every rerun.
# Edits OUTSIDE that block (custom env vars, code-reviewer overrides, build
# tooling hints, etc.) are preserved verbatim.
#
# Never add a second copy of a setup-managed key outside the block. The
# validator and `./setup.init --verify` both fail on duplicates because the
# loader's "last assignment wins" rule turns duplicates into silent overrides.
# =============================================================================

# >>> agent-skills setup.init
# Generated by ./setup.init. The block between these markers is OVERWRITTEN on
# every rerun. To keep changes, edit values OUTSIDE the markers, or rerun
# setup.init with the values you want.
#
# Each value is annotated with: REQUIRED-WHEN, EXAMPLE, and HOW-TO-OVERRIDE.

# Display name used in prompts, summaries, and stakeholder-ready output.
# REQUIRED-WHEN: always (used by every skill). EXAMPLE: "Acme Platform".
ORG_NAME="Local Workspace"

# Email/identity domain for the org. REQUIRED-WHEN: producing PR descriptions
# or release notes that mention owners. EXAMPLE: "acme.example.com". Leave as
# "localhost" for purely local dry runs.
ORG_DOMAIN="localhost"

# Root directory containing all repos the agent should know about.
# REQUIRED-WHEN: always. EXAMPLE: "/Users/you/work". setup.init fills this in.
WORKSPACE_ROOT="${WORKSPACE_ROOT:-$PWD}"

# GitHub organisation or user that owns the repos.
# REQUIRED-WHEN: cloning, pushing, or opening PRs. EXAMPLE: "acme-eng".
# Leave blank for fully offline / read-only planning work.
GITHUB_ORG=""

# Default base branch for new feature work when a project has no override.
# REQUIRED-WHEN: implementation or PR-aware skills. EXAMPLE: "main".
GITHUB_DEFAULT_BRANCH="main"

# Multi-project workspace map. JSON array; one entry per repo the agent should
# know about. setup.init auto-detects sibling git repos and fills this in.
# REQUIRED-WHEN: any repository-aware skill. The bootstrap default below maps a
# single placeholder project so the loader does not error on first run.
#
# Per-project keys:
#   name             short identifier
#   path             relative path under ${WORKSPACE_ROOT}
#   stack            java | typescript | python | go | mixed | other
#   base_branch      overrides ${GITHUB_DEFAULT_BRANCH} for this project
#   build            full build-and-test command
#   format           formatter command (run before commit)
#   runtime_version  (optional) e.g. "21" for Java, "20" for Node, "3.12" for Python
#   coverage_target  (optional) percentage; overrides ${COVERAGE_TARGET_PERCENT}
#   notes            (optional) free-text reminders
PROJECTS_JSON='[
  {"name":"current-workspace", "path":".", "stack":"other", "base_branch":"main", "build":"", "format":"", "runtime_version":"", "notes":"Bootstrap default. Replace with real repo entries for implementation, review, or PR work."}
]'

# -----------------------------------------------------------------------------
# Jira (REQUIRED only when Jira is the issue source)
#
# Discovery contract. Skills read Jira config in this order: process env →
# `.env.local` → `.env` (this file) → `.jira-config.yml` (placeholder source
# only). Real values live here and in the process environment; `.jira-config.yml`
# uses `${JIRA_HOST}` style placeholders that must be resolved from this file.
# Run `python3 scripts/auth-preflight.py` to check resolution without printing
# secrets. See `docs/auth-discovery.md` for the full discovery contract.
# -----------------------------------------------------------------------------
# Pointer to the optional Jira CLI YAML config in the workspace root.
JIRA_CONFIG_FILE="${WORKSPACE_ROOT}/.jira-config.yml"

# Jira host. EXAMPLE: "https://acme.atlassian.net". No trailing slash.
JIRA_HOST=""

# Jira auth type. "bearer" (PAT / API token) or "basic" (email + token).
JIRA_AUTH_TYPE="bearer"

# Jira login. EXAMPLE: "person@acme.example.com". Optional with bearer.
JIRA_LOGIN=""

# Jira API token / PAT. SECRET — NEVER commit this file.
JIRA_API_TOKEN=""

# Comma-separated Jira project keys (the prefix in ticket IDs).
# EXAMPLE: "ABC,PLAT,KVB" so ABC-123, PLAT-9, and KVB-42 are recognised.
# This is NOT the API token. Use uppercase short codes only.
JIRA_PROJECT_KEYS=""

# Regex used to extract a ticket key from a branch name or arbitrary text.
JIRA_KEY_REGEX="[A-Z][A-Z0-9_]+-[0-9]+"

# -----------------------------------------------------------------------------
# Confluence (OPTIONAL — only when tickets reference Confluence pages)
#
# `CONFLUENCE_HOST` blank means "Confluence not configured" — skills MUST skip
# Confluence rather than stop. Same discovery order as Jira (process env →
# `.env.local` → `.env` → `.jira-config.yml`). The auth preflight reports
# Confluence usability separately from Jira and exits 0 when only Jira is
# usable.
# -----------------------------------------------------------------------------
# Confluence host. EXAMPLE: "https://acme.atlassian.net/wiki" for Atlassian
# Cloud, or "https://confluence.acme.example.com" for self-hosted.
CONFLUENCE_HOST=""

# Confluence login (usually the same email as JIRA_LOGIN on Atlassian Cloud).
CONFLUENCE_LOGIN=""

# Confluence API token. SECRET — NEVER commit this file.
CONFLUENCE_API_TOKEN=""

# Optional comma-separated Confluence space keys the agent may consult.
# EXAMPLE: "ENG,ARCH,RUN".
CONFLUENCE_SPACE_KEYS=""

# -----------------------------------------------------------------------------
# SonarQube / SonarCloud (OPTIONAL — only when CI/CD publishes a Sonar report)
# -----------------------------------------------------------------------------
# Sonar host. EXAMPLE: "https://sonar.example.com" or
# "https://sonarcloud.io". Leave blank if you do not use Sonar.
SONAR_HOST_URL=""

# Sonar user token (used by code-reviewer / software-engineer to fetch the
# server-side ruleset and project quality-gate status when the network allows).
# SECRET — NEVER commit this file. Leave blank to skip.
SONAR_TOKEN=""

# -----------------------------------------------------------------------------
# Environment access pointers (OPTIONAL — used by issue-investigator)
# -----------------------------------------------------------------------------
# JSON array describing the deployed environments where issues actually occur,
# so the investigator can collect READ-ONLY evidence (logs, metrics, deployed
# config) instead of guessing from local state.
#
# This file stores POINTERS ONLY. Never put SSH private keys, passwords, or
# production credentials here. Real credentials stay where the OS already
# manages them: ~/.ssh, kubeconfig, your log-aggregator login, your cloud CLI.
#
# Per-environment keys (all optional, but include enough for the agent to
# tell you which command to run, and what to run it against):
#   name             short identifier, e.g. "qa", "staging", "prod-eu"
#   type             test | qa | staging | prod | other
#   access           ssh | kubectl | log-aggregator | cloud-console | none
#   ssh_target       (ssh) user@host or Host alias from ~/.ssh/config
#   kubectl_context  (kubectl) context name from kubeconfig
#   namespace        (kubectl) default namespace, e.g. "payments"
#   log_paths        free-form list of typical log locations or queries
#   log_aggregator   (log-aggregator) URL to Splunk/ELK/Datadog/CloudWatch
#   notes            anything else the investigator should know (RBAC, jump
#                    host, ticket-required-for-prod, agent-must-not-run-itself)
#
# READ-ONLY DISCIPLINE: the investigator skill treats every entry as read-only
# by construction. For `type: prod`, the default behaviour is to PROPOSE the
# command and ask the user to run it themselves. See the issue-investigator
# SKILL.md "Environment Evidence Access" section.
ENVIRONMENTS_JSON='[]'

# <<< agent-skills setup.init

# =============================================================================
# Manual / advanced configuration below.
# Everything from here on is OUTSIDE the setup.init managed block and will be
# preserved across reruns. Add your own overrides freely.
# =============================================================================

# -----------------------------------------------------------------------------
# Example multi-project map to adapt when ready (run setup.init again to apply
# changes inside the managed block above).
# -----------------------------------------------------------------------------
# PROJECTS_JSON_EXAMPLE='[
#   {"name":"example-api", "path":"example-api", "stack":"java",       "base_branch":"main", "build":"mvn clean verify",   "format":"mvn fmt:format && mvn fmt:check", "runtime_version":"21"},
#   {"name":"example-web", "path":"example-web", "stack":"typescript", "base_branch":"main", "build":"npm ci && npm test", "format":"npm run lint && npm run format:check", "runtime_version":"20"}
# ]'

# -----------------------------------------------------------------------------
# Source control (hint strings only)
# -----------------------------------------------------------------------------
GIT_COMMIT_MSG_FORMAT="<TICKET> <Brief description>"
GIT_BRANCH_NAME_FORMAT="feature/<TICKET>-<short-desc>"
GIT_MERGE_STRATEGY="squash"                    # squash | merge | rebase

# -----------------------------------------------------------------------------
# Issue Investigator (OPTIONAL cache settings)
# -----------------------------------------------------------------------------
ISSUE_INVESTIGATOR_CACHE_DIR="${WORKSPACE_ROOT}/.cache/issue-investigator"
ISSUE_INVESTIGATOR_CACHE_TTL_HOURS="24"

# -----------------------------------------------------------------------------
# Code Reviewer (safe defaults)
# -----------------------------------------------------------------------------
# Model routing is intentionally NOT configurable here. The code-reviewer skill
# uses whichever model the host (Copilot Chat, Claude Code, Cursor, etc.) is
# already routing the conversation to. Adding a second routing knob inside the
# skill caused real confusion in v0.19.0 and earlier (operators thought they
# had to set it; the host's default was always the right answer). It was
# removed in v0.20.0.
CODE_REVIEWER_BLOCKING="false"                 # false (advisory) | true (block on blocker findings)

CODE_REVIEWER_MAX_FILES="80"                   # Warn if non-trivial files exceed this
CODE_REVIEWER_MAX_DIFF_CHARS="60000"           # Diff character budget sent to the model
CODE_REVIEWER_CACHE_DIR="${WORKSPACE_ROOT}/.cache/code-reviewer"
CODE_REVIEWER_CACHE_TTL_HOURS="24"             # Issue-context fetch cache TTL
# Severities to display: comma-separated subset of blocker,major,minor,nit
CODE_REVIEWER_SHOW_SEVERITIES="blocker,major,minor,nit"
# Inner-loop trigger: review only blocker/major after Implementation phase
CODE_REVIEWER_INNER_LOOP_SEVERITIES="blocker,major"

# -----------------------------------------------------------------------------
# Build / runtime tooling (OPTIONAL — used by software-engineer for hints)
# -----------------------------------------------------------------------------
JDK_MANAGER="jenv"                             # jenv | sdkman | none
NODE_MANAGER="nvm"                             # nvm | volta | none
PYTHON_MANAGER="pyenv"                         # pyenv | conda | none
DOCKER_REQUIRED="true"                         # true if Testcontainers/compose is common

# -----------------------------------------------------------------------------
# Cross-project / shared library detection (OPTIONAL)
# Comma-separated patterns. Used by code-reviewer to flag downstream impact.
# -----------------------------------------------------------------------------
SHARED_LIBRARY_NAMES="shared-core,shared-utils,auth-starter"
API_MODULE_PATTERNS="-api/,/api/"
SECURITY_CONFIG_PATTERNS="SecurityConfig,WebSecurity,securityFilterChain,OAuth,Keycloak"
MIGRATION_PATH_PATTERNS="db/changelog/,liquibase/,migrations/"

# -----------------------------------------------------------------------------
# Quality gates (OPTIONAL)
# Note: SONAR_HOST_URL and SONAR_TOKEN now live INSIDE the setup.init managed
# block above. Run ./setup.init --with-sonar to fill them in.
# -----------------------------------------------------------------------------
COVERAGE_TARGET_PERCENT="80"

# -----------------------------------------------------------------------------
# Extra context URLs (OPTIONAL — free-form list of links agents may consult)
# JSON array of {name, url, description}
# -----------------------------------------------------------------------------
IMPORTANT_URLS_JSON='[
  {"name":"Engineering handbook","url":"https://docs.example.org/engineering","description":"House style and process"},
  {"name":"Runbook index","url":"https://docs.example.org/runbooks","description":"On-call runbooks"}
]'
