#!/usr/bin/env bash
# agent-skills first-run setup.
#
# Creates or refreshes the workspace-local files agent-skills needs:
#   - <workspace>/.env                 (managed marker block: org, projects,
#                                       Jira, Confluence)
#   - <workspace>/.jira-config.yml     (only with --with-jira or interactive yes)
#   - <workspace>/.skills              (symlink to agent-skills/skills)
#   - <workspace>/.gitignore           (idempotent agent-skills block)
#
# Tested on macOS and Linux with bash 3.2+. Windows users should run via WSL or
# Git Bash; native PowerShell is not supported.
#
# Security:
#   - Secrets (Jira / Confluence tokens) are read silently and NEVER echoed.
#   - Generated `.env` and `.jira-config.yml` are added to `.gitignore`.
#   - The script never logs token values.

set -euo pipefail

START_MARKER="# >>> agent-skills setup.init"
END_MARKER="# <<< agent-skills setup.init"

# Setup-managed keys must appear inside the marker block exactly once.
# Used to deduplicate legacy `.env` files that pre-date the marker discipline.
MANAGED_KEYS=(
  ORG_NAME
  ORG_DOMAIN
  WORKSPACE_ROOT
  GITHUB_ORG
  GITHUB_DEFAULT_BRANCH
  PROJECTS_JSON
  JIRA_CONFIG_FILE
  JIRA_HOST
  JIRA_AUTH_TYPE
  JIRA_LOGIN
  JIRA_API_TOKEN
  JIRA_PROJECT_KEYS
  JIRA_KEY_REGEX
  CONFLUENCE_HOST
  CONFLUENCE_LOGIN
  CONFLUENCE_API_TOKEN
  CONFLUENCE_SPACE_KEYS
  SONAR_HOST_URL
  SONAR_TOKEN
  ENVIRONMENTS_JSON
)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_WORKSPACE_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

ASSUME_YES="false"
JIRA_MODE="ask"
CONFLUENCE_MODE="ask"
SONAR_MODE="ask"
ENVIRONMENTS_MODE="ask"
SYMLINK_MODE="ask"
VERIFY_MODE="false"
CHECK_UPDATES_MODE="false"
UPDATE_MODE="false"
UPDATE_REF=""
CHECK_CONNECTIVITY="true"
CHECK_CREDENTIAL_PROBE="true"
WORKSPACE_ROOT=""
WORKSPACE_ROOT_EXPLICIT="false"

usage() {
  cat <<'EOF'
Usage: ./setup.init [options]

Create or update the workspace-local files agent-skills needs for a first run,
or verify an existing setup.

Options:
  --workspace-root PATH    Workspace root where .env, .jira-config.yml, and
                           .skills live
  --yes                    Accept safe defaults for all prompts
  --with-jira              Create/update .jira-config.yml and Jira env values
  --no-jira                Skip Jira setup
  --with-confluence        Prompt for Confluence host/login/token
  --no-confluence          Skip Confluence setup
  --with-sonar             Prompt for SonarQube host/token
  --no-sonar               Skip SonarQube setup
  --with-environments      Prompt for deployed environment access pointers
                           (read-only ssh/kubectl/log-aggregator targets used
                           by the issue-investigator skill)
  --no-environments        Skip environment-access pointers
  --no-connectivity-check  Skip the optional curl reachability check on the
                           Jira/Confluence/Sonar hosts (useful behind a VPN
                           that blocks the host)
  --no-credential-probe    Skip the warn-only credential blast-radius probe
                           that flags destructive-capable cloud / k8s / DB
                           credentials in the shell or .env (see
                           docs/destructive-action-safety.md)
  --no-symlink             Do not create the .skills symlink
  --verify                 Check an existing setup and report problems
                           (no writes)
  --check-updates          Compare local VERSION against the latest release
                           tag on origin and exit. No writes. Exit codes:
                             0 up-to-date / ahead, 10 update available,
                             2 setup error.
  --update                 Apply the latest release: fetch tags, check out
                           the latest tag (or --branch), refresh .skills and
                           .agent-skills.lock. Refuses if working tree dirty.
  --branch NAME            Used with --update; track this branch instead of
                           the latest tag (e.g. main).
  --help                   Show this help

Typical use:
  cd agent-skills
  ./setup.init                        # interactive first run
  ./setup.init --verify               # check an existing setup

Non-interactive bootstrap:
  ./setup.init --yes --no-jira --no-confluence \
      --workspace-root /path/to/workspace
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --workspace-root)
      WORKSPACE_ROOT="${2:-}"
      WORKSPACE_ROOT_EXPLICIT="true"
      shift 2
      ;;
    --workspace-root=*)
      WORKSPACE_ROOT="${1#*=}"
      WORKSPACE_ROOT_EXPLICIT="true"
      shift
      ;;
    --yes) ASSUME_YES="true"; shift ;;
    --with-jira) JIRA_MODE="yes"; shift ;;
    --no-jira) JIRA_MODE="no"; shift ;;
    --with-confluence) CONFLUENCE_MODE="yes"; shift ;;
    --no-confluence) CONFLUENCE_MODE="no"; shift ;;
    --with-sonar) SONAR_MODE="yes"; shift ;;
    --no-sonar) SONAR_MODE="no"; shift ;;
    --with-environments) ENVIRONMENTS_MODE="yes"; shift ;;
    --no-environments) ENVIRONMENTS_MODE="no"; shift ;;
    --no-connectivity-check) CHECK_CONNECTIVITY="false"; shift ;;
    --no-credential-probe) CHECK_CREDENTIAL_PROBE="false"; shift ;;
    --no-symlink) SYMLINK_MODE="no"; shift ;;
    --verify) VERIFY_MODE="true"; shift ;;
    --check-updates) CHECK_UPDATES_MODE="true"; shift ;;
    --update) UPDATE_MODE="true"; shift ;;
    --branch)
      UPDATE_REF="${2:-}"; shift 2 ;;
    --branch=*)
      UPDATE_REF="${1#*=}"; shift ;;
    --help|-h) usage; exit 0 ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

is_interactive() {
  [[ "${ASSUME_YES}" != "true" && -t 0 ]]
}

# ------------------------------------------------------------------------------
# Prompt helpers
#
# show_help_block() prints the example/required guidance to stderr exactly once
# per prompt so the user understands what value is expected.
# ------------------------------------------------------------------------------
show_help_block() {
  local help_text="$1"
  [[ -n "${help_text}" ]] || return 0
  if is_interactive; then
    while IFS= read -r line; do
      printf '    %s\n' "${line}" >&2
    done <<< "${help_text}"
  fi
}

prompt() {
  local label="$1"
  local default_value="$2"
  local help_text="${3:-}"
  local validator="${4:-}"
  local answer=""
  local attempts=0

  while :; do
    attempts=$((attempts + 1))
    if is_interactive; then
      show_help_block "${help_text}"
      if [[ -n "${default_value}" ]]; then
        printf '%s [%s]: ' "${label}" "${default_value}" >&2
      else
        printf '%s: ' "${label}" >&2
      fi
      IFS= read -r answer || true
      [[ -z "${answer}" ]] && answer="${default_value}"
    else
      answer="${default_value}"
    fi

    if [[ -z "${validator}" ]] || "${validator}" "${answer}"; then
      printf '%s' "${answer}"
      return 0
    fi

    if ! is_interactive || [[ "${attempts}" -ge 3 ]]; then
      # Non-interactive or exhausted retries: return whatever we have so the
      # caller can decide. Validation errors are surfaced by the validator.
      printf '%s' "${answer}"
      return 0
    fi
  done
}

prompt_secret() {
  local label="$1"
  local help_text="${2:-}"
  local answer=""

  if is_interactive; then
    show_help_block "${help_text}"
    printf '    NOTE: input is hidden. The value is written ONLY to gitignored .env.\n' >&2
    printf '%s: ' "${label}" >&2
    IFS= read -r -s answer || true
    printf '\n' >&2
  fi
  printf '%s' "${answer}"
}

confirm() {
  local label="$1"
  local default_value="$2"
  local answer=""

  if [[ "${ASSUME_YES}" == "true" ]]; then
    [[ "${default_value}" == "yes" ]]
    return
  fi
  if ! is_interactive; then
    [[ "${default_value}" == "yes" ]]
    return
  fi

  if [[ "${default_value}" == "yes" ]]; then
    printf '%s [Y/n]: ' "${label}" >&2
  else
    printf '%s [y/N]: ' "${label}" >&2
  fi
  IFS= read -r answer || true
  answer="$(printf '%s' "${answer}" | tr '[:upper:]' '[:lower:]')"
  [[ -z "${answer}" ]] && answer="${default_value}"
  [[ "${answer}" == "y" || "${answer}" == "yes" ]]
}

# ------------------------------------------------------------------------------
# Validators (return 0 on accept, non-zero on reject; print rejection to stderr)
# ------------------------------------------------------------------------------
validate_optional() {
  return 0
}

validate_url() {
  local value="$1"
  [[ -z "${value}" ]] && return 0
  if [[ "${value}" =~ ^https?://[A-Za-z0-9._-]+(:[0-9]+)?(/.*)?$ ]]; then
    return 0
  fi
  echo "    ! Value does not look like a URL (expected https://host[/path])." >&2
  return 1
}

validate_email_or_blank() {
  local value="$1"
  [[ -z "${value}" ]] && return 0
  if [[ "${value}" =~ ^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$ ]]; then
    return 0
  fi
  # Allow plain logins (e.g. service accounts) but warn.
  if [[ "${value}" =~ ^[A-Za-z0-9._-]+$ ]]; then
    return 0
  fi
  echo "    ! Value does not look like an email or login." >&2
  return 1
}

validate_project_keys() {
  local value="$1"
  [[ -z "${value}" ]] && return 0
  # Reject obvious API-token shapes (long random string with no comma).
  if [[ "${#value}" -ge 20 && ! "${value}" =~ , && ! "${value}" =~ -[0-9]+ ]]; then
    if [[ "${value}" =~ [a-z] && "${value}" =~ [A-Z0-9] ]]; then
      echo "    ! That looks like an API token, not project keys. Project keys are short uppercase codes like ABC,PLAT,KVB." >&2
      return 1
    fi
  fi
  local IFS=','
  local part
  for part in ${value}; do
    part="$(printf '%s' "${part}" | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')"
    [[ -z "${part}" ]] && continue
    if [[ ! "${part}" =~ ^[A-Z][A-Z0-9_]{1,9}$ ]]; then
      echo "    ! '${part}' does not look like a Jira project key (uppercase, 2-10 chars, e.g. ABC, PLAT, KVB)." >&2
      return 1
    fi
  done
  return 0
}

validate_org_name() {
  local value="$1"
  [[ -n "${value}" ]] && return 0
  echo "    ! Display name cannot be empty." >&2
  return 1
}

validate_branch_name() {
  local value="$1"
  [[ -z "${value}" ]] && return 1
  if [[ "${value}" =~ ^[A-Za-z0-9._/-]+$ ]]; then
    return 0
  fi
  echo "    ! Branch name contains unusual characters." >&2
  return 1
}

# ------------------------------------------------------------------------------
# Inference helpers
# ------------------------------------------------------------------------------

# Infer "Acme Platform" from "acme-platform" / "acme_platform" / "AcmePlatform".
prettify_slug() {
  local slug="$1"
  printf '%s' "${slug}" \
    | sed -E 's/[._-]+/ /g; s/([a-z])([A-Z])/\1 \2/g' \
    | awk '{
        for (i = 1; i <= NF; i++) {
          $i = toupper(substr($i, 1, 1)) tolower(substr($i, 2));
        }
        print
      }'
}

# Extract host from "https://acme.atlassian.net/wiki" => "acme.atlassian.net".
extract_host() {
  local url="$1"
  printf '%s' "${url}" | sed -E 's#^https?://##; s#/.*$##; s#:.*$##'
}

# Infer org slug from a Jira host: acme.atlassian.net -> acme.
infer_org_from_jira_host() {
  local host
  host="$(extract_host "$1")"
  if [[ "${host}" == *.atlassian.net ]]; then
    printf '%s' "${host%%.atlassian.net}"
    return 0
  fi
  # Self-hosted: jira.acme.example.com -> acme; confluence.acme.com -> acme.
  if [[ "${host}" =~ ^(jira|confluence|wiki)\.(.+)$ ]]; then
    local rest="${BASH_REMATCH[2]}"
    printf '%s' "${rest%%.*}"
    return 0
  fi
  printf '%s' "${host%%.*}"
}

# Infer the likely Confluence host from a Jira host.
infer_confluence_from_jira() {
  local jira="$1"
  [[ -z "${jira}" ]] && return 1
  local host
  host="$(extract_host "${jira}")"
  if [[ "${host}" == *.atlassian.net ]]; then
    printf 'https://%s/wiki' "${host}"
    return 0
  fi
  # Self-hosted: replace leading "jira." with "confluence." if present.
  if [[ "${host}" == jira.* ]]; then
    printf 'https://confluence.%s' "${host#jira.}"
    return 0
  fi
  printf 'https://%s' "${host}"
}

# Infer the org email domain from a login email, GitHub org, or Jira host.
infer_org_domain() {
  local jira_login="$1"
  local github_org="$2"
  local jira_host="$3"
  if [[ "${jira_login}" =~ @([A-Za-z0-9.-]+\.[A-Za-z]{2,})$ ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ -n "${jira_host}" ]]; then
    local host
    host="$(extract_host "${jira_host}")"
    [[ -n "${host}" ]] && { printf '%s' "${host}"; return 0; }
  fi
  if [[ -n "${github_org}" ]]; then
    printf '%s.example.com' "${github_org}"
    return 0
  fi
  printf 'localhost'
}

# Detect a Jira project key from a ticket key (ABC-123) or ticket URL.
extract_project_key_from_ticket() {
  local input="$1"
  [[ -z "${input}" ]] && return 1
  if [[ "${input}" =~ /browse/([A-Z][A-Z0-9_]+)-[0-9]+ ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ "${input}" =~ ^([A-Z][A-Z0-9_]+)-[0-9]+$ ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return 0
  fi
  return 1
}

# Mask a secret for display (never used for real secrets in practice).
mask_secret() {
  local value="$1"
  local len="${#value}"
  if [[ "${len}" -le 6 ]]; then
    [[ "${len}" -gt 0 ]] && printf '****'
  else
    printf '****%s' "${value: -4}"
  fi
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

shell_escape_double_quoted() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/`/\\`/g; s/\$/\\$/g'
}

# ------------------------------------------------------------------------------
# Connectivity check (warn-only)
#
# Probes a host with a HEAD request and a short timeout. ANY HTTP response
# (including 401/403) counts as reachable, because credentials may not be
# valid yet at setup time. Prints WARN lines but never fails the run; corp
# VPNs / firewalls are a common false negative.
# ------------------------------------------------------------------------------
check_url_reachable() {
  local label="$1"
  local url="$2"
  [[ -z "${url}" ]] && return 0
  [[ "${CHECK_CONNECTIVITY}" == "true" ]] || return 0
  command -v curl >/dev/null 2>&1 || return 0
  local code=""
  code="$(curl -ksS --head -m 5 -o /dev/null -w '%{http_code}' "${url}" 2>/dev/null || true)"
  if [[ -z "${code}" || "${code}" == "000" ]]; then
    echo "  WARN: ${label} (${url}) is not reachable from this network." >&2
    echo "        This may be expected on VPN-only or air-gapped setups." >&2
    echo "        Re-run with --no-connectivity-check to skip this probe." >&2
    return 0
  fi
  echo "  ok    ${label} reachable (HTTP ${code})"
}

# ------------------------------------------------------------------------------
# Credential blast-radius probe (warn-only)
#
# Inspects the configured .env / .agent-skills.yml plus the current shell
# environment for credential-shaped values that would let an agent perform
# destructive cloud / orchestrator / database operations against production
# (delete buckets, terminate instances, drop databases, delete snapshots,
# rotate IAM, etc.). Prints WARN lines pointing at the offending name and
# the recommended scoping; never fails the run.
#
# This is heuristic and intentionally generic. It does NOT inspect cloud-
# provider IAM policies — it cannot. It flags the *presence* of broad
# credentials so the operator can confirm scoping before letting any agent
# inherit them. See docs/destructive-action-safety.md.
#
# Skip with --no-credential-probe.
# ------------------------------------------------------------------------------
check_credential_blast_radius() {
  [[ "${CHECK_CREDENTIAL_PROBE}" == "true" ]] || return 0
  echo ""
  echo "Credential blast-radius probe (warn-only; --no-credential-probe to skip):"
  echo "  See docs/destructive-action-safety.md for the full safety floor."

  local found=0
  local sources=()
  [[ -f "${ENV_FILE}" ]] && sources+=("${ENV_FILE}")

  # Names that, when present at the agent's session, typically grant
  # destructive privileges unless an explicit least-privilege role is used.
  local risky_env_names=(
    AWS_ACCESS_KEY_ID
    AWS_SECRET_ACCESS_KEY
    AWS_SESSION_TOKEN
    GOOGLE_APPLICATION_CREDENTIALS
    GCP_SERVICE_ACCOUNT_KEY
    AZURE_CLIENT_SECRET
    AZURE_SUBSCRIPTION_ID
    DIGITALOCEAN_TOKEN
    DO_API_TOKEN
    LINODE_TOKEN
    HCLOUD_TOKEN
    KUBECONFIG
    DOCKER_HOST
    TF_VAR_aws_access_key
    DATABASE_ADMIN_URL
    POSTGRES_ADMIN_PASSWORD
    MONGODB_ADMIN_URI
  )

  local present_in_shell=()
  local name
  for name in "${risky_env_names[@]}"; do
    if [[ -n "${!name:-}" ]]; then
      present_in_shell+=("${name}")
    fi
  done

  if (( ${#present_in_shell[@]} > 0 )); then
    found=1
    echo "  WARN: the following destructive-capable credentials are exported in"
    echo "        this shell and would be inherited by any agent process you"
    echo "        launch from here:"
    for name in "${present_in_shell[@]}"; do
      echo "          - ${name}"
    done
    echo "        Recommended: scope these to a least-privilege role with NO"
    echo "        delete-bucket / terminate-instance / drop-database /"
    echo "        delete-snapshot / IAM-modify / backup-mutation privileges."
    echo "        See docs/destructive-action-safety.md#production-boundary."
  fi

  # Walk the configured .env (if present) for credential-shaped names AND
  # values inside the setup-managed marker block. We only flag NAMES outside
  # the marker block so we do not false-positive on the agent-skills setup
  # keys; tokens inside the marker block are intentional (Jira / Confluence /
  # Sonar) and have their own least-privilege expectation.
  local src
  local in_marker=0
  local risky_in_env=()
  if [[ -f "${ENV_FILE}" ]]; then
    while IFS= read -r line || [[ -n "${line}" ]]; do
      if [[ "${line}" == "# >>> agent-skills setup.init"* ]]; then
        in_marker=1
        continue
      fi
      if [[ "${line}" == "# <<< agent-skills setup.init"* ]]; then
        in_marker=0
        continue
      fi
      [[ "${in_marker}" -eq 1 ]] && continue
      [[ "${line}" =~ ^[[:space:]]*# ]] && continue
      [[ -z "${line//[[:space:]]/}" ]] && continue
      # Match KEY=value where KEY hints at destructive scope.
      if [[ "${line}" =~ ^[[:space:]]*(export[[:space:]]+)?(AWS_ACCESS_KEY_ID|AWS_SECRET_ACCESS_KEY|AWS_SESSION_TOKEN|GOOGLE_APPLICATION_CREDENTIALS|GCP_SERVICE_ACCOUNT_KEY|AZURE_CLIENT_SECRET|DIGITALOCEAN_TOKEN|DO_API_TOKEN|LINODE_TOKEN|HCLOUD_TOKEN|KUBECONFIG|DATABASE_ADMIN_URL|POSTGRES_ADMIN_PASSWORD|MONGODB_ADMIN_URI)= ]]; then
        risky_in_env+=("${BASH_REMATCH[2]}")
      fi
    done < "${ENV_FILE}"
  fi

  if (( ${#risky_in_env[@]} > 0 )); then
    found=1
    echo "  WARN: the following destructive-capable credentials are defined in"
    echo "        ${ENV_FILE}"
    echo "        OUTSIDE the agent-skills marker block — any agent that"
    echo "        sources this file will inherit them:"
    for name in "${risky_in_env[@]}"; do
      echo "          - ${name}"
    done
    echo "        Recommended: move them to a host secret manager scoped to"
    echo "        the operation, or remove them entirely if not needed for"
    echo "        agent work. Do not commit them. The discovered-credential"
    echo "        protocol forbids the agent from invoking values it"
    echo "        encounters; values it inherits silently from the shell"
    echo "        sidestep that protection."
  fi

  if (( found == 0 )); then
    echo "  ok    no destructive-capable credentials detected in shell or"
    echo "        ${ENV_FILE} (heuristic; cannot inspect cloud-provider IAM"
    echo "        policies — confirm scoping in your provider console)."
  fi
}

# ------------------------------------------------------------------------------
# JSON validation: prefer python3, fall back to ruby. 127 if neither exists.
# ------------------------------------------------------------------------------
validate_json_string() {
  local payload="$1"
  if command -v python3 >/dev/null 2>&1; then
    AGENT_SKILLS_JSON="${payload}" python3 -c \
      'import json,os,sys;sys.exit(0) if json.loads(os.environ["AGENT_SKILLS_JSON"]) is not None else sys.exit(1)' \
      >/dev/null 2>&1
    return $?
  fi
  if command -v ruby >/dev/null 2>&1; then
    AGENT_SKILLS_JSON="${payload}" ruby -rjson -e \
      'JSON.parse(ENV["AGENT_SKILLS_JSON"])' >/dev/null 2>&1
    return $?
  fi
  return 127
}

# ------------------------------------------------------------------------------
# Workspace-root safety
# ------------------------------------------------------------------------------
is_unsafe_workspace_root() {
  local path="$1"
  case "${path}" in
    "/"|"/root"|"/etc"|"/usr"|"/var"|"/opt"|"/private"|"/Library"|"/System"|"/Applications")
      return 0 ;;
  esac
  if [[ -n "${HOME:-}" && "${path}" == "${HOME}" ]]; then
    return 0
  fi
  return 1
}

guard_workspace_root() {
  local path="$1"
  local explicit="$2"
  if ! is_unsafe_workspace_root "${path}"; then
    return 0
  fi
  echo "" >&2
  echo "Refusing to use '${path}' as the workspace root." >&2
  echo "It looks like your home or a system directory." >&2
  echo "" >&2
  echo "Move agent-skills under a parent folder that contains your repos, e.g.:" >&2
  echo "  ~/work/" >&2
  echo "    ├── agent-skills/" >&2
  echo "    ├── repo-a/" >&2
  echo "    └── repo-b/" >&2
  echo "" >&2
  echo "Then run: ./setup.init   (from inside agent-skills)" >&2
  echo "Or pass an explicit path: ./setup.init --workspace-root /path/to/work" >&2
  if [[ "${explicit}" == "true" ]] && is_interactive; then
    echo "" >&2
    if confirm "I really want to write into '${path}' anyway" "no"; then
      return 0
    fi
  fi
  exit 2
}

# ------------------------------------------------------------------------------
# Stack and command detection
# ------------------------------------------------------------------------------
detect_stack() {
  local repo_path="$1"
  if [[ -f "${repo_path}/pom.xml" || -f "${repo_path}/build.gradle" || -f "${repo_path}/build.gradle.kts" ]]; then
    printf 'java'
  elif [[ -f "${repo_path}/package.json" ]]; then
    printf 'typescript'
  elif [[ -f "${repo_path}/pyproject.toml" || -f "${repo_path}/requirements.txt" || -f "${repo_path}/setup.py" ]]; then
    printf 'python'
  elif [[ -f "${repo_path}/go.mod" ]]; then
    printf 'go'
  else
    printf 'other'
  fi
}

detect_node_package_manager() {
  local repo_path="$1"
  if [[ -f "${repo_path}/pnpm-lock.yaml" ]]; then printf 'pnpm'
  elif [[ -f "${repo_path}/yarn.lock" ]]; then printf 'yarn'
  elif [[ -f "${repo_path}/bun.lockb" ]]; then printf 'bun'
  else printf 'npm'
  fi
}

node_has_script() {
  local pkg="$1"
  local script="$2"
  [[ -f "${pkg}" ]] || return 1
  if command -v python3 >/dev/null 2>&1; then
    AGENT_SKILLS_PKG="${pkg}" AGENT_SKILLS_SCRIPT="${script}" python3 -c '
import json, os, sys
try:
    with open(os.environ["AGENT_SKILLS_PKG"]) as fh:
        data = json.load(fh)
    sys.exit(0 if (data.get("scripts") or {}).get(os.environ["AGENT_SKILLS_SCRIPT"]) else 1)
except Exception:
    sys.exit(1)
' >/dev/null 2>&1
    return $?
  fi
  grep -q "\"${script}\"[[:space:]]*:" "${pkg}"
}

default_build_for_stack() {
  local stack="$1"
  local repo_path="$2"
  case "${stack}" in
    java)
      if [[ -f "${repo_path}/mvnw" ]]; then printf './mvnw test'
      elif [[ -f "${repo_path}/pom.xml" ]]; then printf 'mvn test'
      elif [[ -f "${repo_path}/gradlew" ]]; then printf './gradlew test'
      elif [[ -f "${repo_path}/build.gradle" || -f "${repo_path}/build.gradle.kts" ]]; then printf 'gradle test'
      else printf ''
      fi
      ;;
    typescript)
      local mgr
      mgr="$(detect_node_package_manager "${repo_path}")"
      if node_has_script "${repo_path}/package.json" "test"; then
        case "${mgr}" in
          npm)  printf 'npm test' ;;
          yarn) printf 'yarn test' ;;
          pnpm) printf 'pnpm test' ;;
          bun)  printf 'bun test' ;;
        esac
      elif node_has_script "${repo_path}/package.json" "build"; then
        case "${mgr}" in
          npm)  printf 'npm run build' ;;
          yarn) printf 'yarn build' ;;
          pnpm) printf 'pnpm build' ;;
          bun)  printf 'bun run build' ;;
        esac
      else
        printf '%s install' "${mgr}"
      fi
      ;;
    python)
      if [[ -f "${repo_path}/pyproject.toml" ]] && grep -q '\[tool.poetry\]' "${repo_path}/pyproject.toml" 2>/dev/null; then
        printf 'poetry run pytest'
      else
        printf 'pytest'
      fi
      ;;
    go) printf 'go test ./...' ;;
    *) printf '' ;;
  esac
}

default_format_for_stack() {
  local stack="$1"
  local repo_path="$2"
  case "${stack}" in
    typescript)
      local mgr
      mgr="$(detect_node_package_manager "${repo_path}")"
      if node_has_script "${repo_path}/package.json" "lint"; then
        case "${mgr}" in
          npm)  printf 'npm run lint' ;;
          yarn) printf 'yarn lint' ;;
          pnpm) printf 'pnpm lint' ;;
          bun)  printf 'bun run lint' ;;
        esac
      else
        printf ''
      fi
      ;;
    python) printf 'ruff check . && ruff format --check .' ;;
    go) printf 'gofmt -l .' ;;
    *) printf '' ;;
  esac
}

# ------------------------------------------------------------------------------
# GitHub org detection
# ------------------------------------------------------------------------------
detect_github_org_from_siblings() {
  local workspace_root="$1"
  local repo_path="" url="" org=""
  for repo_path in "${workspace_root}"/*; do
    [[ -d "${repo_path}/.git" ]] || continue
    [[ "$(basename "${repo_path}")" == "agent-skills" ]] && continue
    command -v git >/dev/null 2>&1 || continue
    url="$(git -C "${repo_path}" config --get remote.origin.url 2>/dev/null || true)"
    [[ -n "${url}" ]] || continue
    if [[ "${url}" =~ github\.com[:/]+([^/]+)/[^/]+$ ]]; then
      org="${BASH_REMATCH[1]}"
      org="${org%.git}"
      printf '%s' "${org}"
      return 0
    fi
  done
  return 1
}

detect_projects_json() {
  local workspace_root="$1"
  local default_branch="$2"
  local project_count=0
  local repo_path="" repo_name="" stack="" build="" format=""
  printf '[\n'
  for repo_path in "${workspace_root}"/*; do
    [[ -d "${repo_path}" ]] || continue
    [[ -d "${repo_path}/.git" ]] || continue
    repo_name="$(basename "${repo_path}")"
    [[ "${repo_name}" == "agent-skills" ]] && continue
    stack="$(detect_stack "${repo_path}")"
    build="$(default_build_for_stack "${stack}" "${repo_path}")"
    format="$(default_format_for_stack "${stack}" "${repo_path}")"
    if [[ "${project_count}" -gt 0 ]]; then
      printf ',\n'
    fi
    printf '  {"name":"%s", "path":"%s", "stack":"%s", "base_branch":"%s", "build":"%s", "format":"%s"}' \
      "$(json_escape "${repo_name}")" \
      "$(json_escape "${repo_name}")" \
      "$(json_escape "${stack}")" \
      "$(json_escape "${default_branch}")" \
      "$(json_escape "${build}")" \
      "$(json_escape "${format}")"
    project_count=$((project_count + 1))
  done
  if [[ "${project_count}" -eq 0 ]]; then
    printf '  {"name":"current-workspace", "path":".", "stack":"other", "base_branch":"%s", "build":"", "format":"", "runtime_version":"", "notes":"Bootstrap default. Replace with real repo entries for implementation, review, or PR work."}' \
      "$(json_escape "${default_branch}")"
  fi
  printf '\n]'
}

count_detected_projects() {
  local workspace_root="$1"
  local count=0 repo_path=""
  for repo_path in "${workspace_root}"/*; do
    [[ -d "${repo_path}/.git" ]] || continue
    [[ "$(basename "${repo_path}")" == "agent-skills" ]] && continue
    count=$((count + 1))
  done
  printf '%s' "${count}"
}

# ------------------------------------------------------------------------------
# Marker-block management
# ------------------------------------------------------------------------------
replace_generated_block() {
  local target_file="$1"
  local block_file="$2"
  local temp_file
  temp_file="$(mktemp)"
  awk -v start="${START_MARKER}" -v end="${END_MARKER}" -v block="${block_file}" '
    BEGIN { in_block = 0; replaced = 0 }
    $0 == start {
      if (!replaced) {
        while ((getline line < block) > 0) print line
        close(block)
        replaced = 1
      }
      in_block = 1
      next
    }
    in_block && $0 == end { in_block = 0; next }
    !in_block { print }
    END {
      if (!replaced) {
        print ""
        while ((getline line < block) > 0) print line
        close(block)
      }
    }
  ' "${target_file}" > "${temp_file}"
  mv "${temp_file}" "${target_file}"
}

# Strip stray top-level assignments of MANAGED_KEYS that live OUTSIDE the
# marker block. Legacy `.env` files (created before marker discipline) often
# contain duplicates. We always normalize so the marker block is the single
# source of truth.
strip_managed_keys_outside_block() {
  local target_file="$1"
  local removed=0
  local key=""
  local pattern=""
  local temp_file
  temp_file="$(mktemp)"

  # Build alternation of MANAGED_KEYS once.
  local joined=""
  for key in "${MANAGED_KEYS[@]}"; do
    [[ -n "${joined}" ]] && joined+="|"
    joined+="${key}"
  done
  pattern="^[[:space:]]*(export[[:space:]]+)?(${joined})[[:space:]]*="

  awk -v start="${START_MARKER}" -v end="${END_MARKER}" -v pat="${pattern}" '
    BEGIN { in_block = 0; in_quote = 0; quote_char = ""; removed = 0 }
    {
      line = $0
      if (line == start) { in_block = 1; print; next }
      if (line == end)   { in_block = 0; print; next }

      if (in_block || in_quote) {
        # Track multiline single-quoted JSON inside the marker block.
        if (in_quote) {
          if (index(line, quote_char) > 0) { in_quote = 0; quote_char = "" }
        } else if (in_block) {
          # Detect start of a single-quoted multi-line value.
          if (match(line, /=[[:space:]]*'\''[^'\'']*$/)) {
            in_quote = 1; quote_char = "'\''"
          }
        }
        print
        next
      }

      if (match(line, pat)) {
        removed++
        next
      }
      print
    }
    END { exit removed > 127 ? 127 : removed }
  ' "${target_file}" > "${temp_file}" || removed=$?

  if ! cmp -s "${target_file}" "${temp_file}"; then
    mv "${temp_file}" "${target_file}"
    if [[ "${removed}" -gt 0 ]]; then
      echo "  Removed ${removed} duplicate setup-managed key(s) outside the marker block."
    fi
  else
    rm -f "${temp_file}"
  fi
}

write_env_block() {
  local env_file="$1"
  local workspace_root="$2"
  local org_name="$3"
  local org_domain="$4"
  local github_org="$5"
  local default_branch="$6"
  local use_jira="$7"
  local jira_host="$8"
  local jira_auth_type="$9"
  local jira_login="${10}"
  local jira_token="${11}"
  local jira_project_keys="${12}"
  local use_confluence="${13}"
  local conf_host="${14}"
  local conf_login="${15}"
  local conf_token="${16}"
  local conf_spaces="${17}"
  local projects_json="${18}"
  local use_sonar="${19}"
  local sonar_host="${20}"
  local sonar_token="${21}"
  local environments_json="${22}"
  local block_file
  block_file="$(mktemp)"

  {
    printf '%s\n' "${START_MARKER}"
    printf '# Generated by ./setup.init. The block between these markers is\n'
    printf '# OVERWRITTEN on every rerun. To keep changes, edit values OUTSIDE\n'
    printf '# the markers, or rerun setup.init with the values you want.\n'
    printf 'ORG_NAME="%s"\n' "$(shell_escape_double_quoted "${org_name}")"
    printf 'ORG_DOMAIN="%s"\n' "$(shell_escape_double_quoted "${org_domain}")"
    printf 'WORKSPACE_ROOT="%s"\n' "$(shell_escape_double_quoted "${workspace_root}")"
    printf 'GITHUB_ORG="%s"\n' "$(shell_escape_double_quoted "${github_org}")"
    printf 'GITHUB_DEFAULT_BRANCH="%s"\n' "$(shell_escape_double_quoted "${default_branch}")"
    printf "PROJECTS_JSON='%s'\n" "${projects_json}"
    printf 'JIRA_CONFIG_FILE="${WORKSPACE_ROOT}/.jira-config.yml"\n'
    if [[ "${use_jira}" == "yes" ]]; then
      printf 'JIRA_HOST="%s"\n' "$(shell_escape_double_quoted "${jira_host}")"
      printf 'JIRA_AUTH_TYPE="%s"\n' "$(shell_escape_double_quoted "${jira_auth_type}")"
      printf 'JIRA_LOGIN="%s"\n' "$(shell_escape_double_quoted "${jira_login}")"
      printf 'JIRA_API_TOKEN="%s"\n' "$(shell_escape_double_quoted "${jira_token}")"
      printf 'JIRA_PROJECT_KEYS="%s"\n' "$(shell_escape_double_quoted "${jira_project_keys}")"
      printf 'JIRA_KEY_REGEX="[A-Z][A-Z0-9_]+-[0-9]+"\n'
    else
      printf 'JIRA_HOST=""\n'
      printf 'JIRA_AUTH_TYPE="bearer"\n'
      printf 'JIRA_LOGIN=""\n'
      printf 'JIRA_API_TOKEN=""\n'
      printf 'JIRA_PROJECT_KEYS=""\n'
      printf 'JIRA_KEY_REGEX="[A-Z][A-Z0-9_]+-[0-9]+"\n'
    fi
    if [[ "${use_confluence}" == "yes" ]]; then
      printf 'CONFLUENCE_HOST="%s"\n' "$(shell_escape_double_quoted "${conf_host}")"
      printf 'CONFLUENCE_LOGIN="%s"\n' "$(shell_escape_double_quoted "${conf_login}")"
      printf 'CONFLUENCE_API_TOKEN="%s"\n' "$(shell_escape_double_quoted "${conf_token}")"
      printf 'CONFLUENCE_SPACE_KEYS="%s"\n' "$(shell_escape_double_quoted "${conf_spaces}")"
    else
      printf 'CONFLUENCE_HOST=""\n'
      printf 'CONFLUENCE_LOGIN=""\n'
      printf 'CONFLUENCE_API_TOKEN=""\n'
      printf 'CONFLUENCE_SPACE_KEYS=""\n'
    fi
    if [[ "${use_sonar}" == "yes" ]]; then
      printf 'SONAR_HOST_URL="%s"\n' "$(shell_escape_double_quoted "${sonar_host}")"
      printf 'SONAR_TOKEN="%s"\n' "$(shell_escape_double_quoted "${sonar_token}")"
    else
      printf 'SONAR_HOST_URL=""\n'
      printf 'SONAR_TOKEN=""\n'
    fi
    printf "ENVIRONMENTS_JSON='%s'\n" "${environments_json}"
    printf '%s\n' "${END_MARKER}"
  } > "${block_file}"

  replace_generated_block "${env_file}" "${block_file}"
  rm -f "${block_file}"
  strip_managed_keys_outside_block "${env_file}"
}

update_jira_project_key() {
  local jira_file="$1"
  local jira_project_keys="$2"
  local first_key="${jira_project_keys%%,*}"
  first_key="$(printf '%s' "${first_key}" | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')"
  [[ -n "${first_key}" ]] || return 0
  local temp_file
  temp_file="$(mktemp)"
  awk -v key="${first_key}" '
    BEGIN { updated = 0 }
    /^[[:space:]]*key:[[:space:]]*/ && !updated {
      sub(/key:[[:space:]]*.*/, "key: " key "                    # Default project key (override per command with -p)")
      updated = 1
    }
    { print }
  ' "${jira_file}" > "${temp_file}"
  mv "${temp_file}" "${jira_file}"
}

# ------------------------------------------------------------------------------
# Workspace .gitignore management
# ------------------------------------------------------------------------------
GITIGNORE_START_MARKER="# >>> agent-skills setup.init"
GITIGNORE_END_MARKER="# <<< agent-skills setup.init"

update_workspace_gitignore() {
  local workspace_root="$1"
  local gitignore_file="${workspace_root}/.gitignore"
  local block_file
  block_file="$(mktemp)"
  {
    printf '%s\n' "${GITIGNORE_START_MARKER}"
    printf '# Local agent-skills workspace files. Safe to keep ignored.\n'
    printf '.env\n'
    printf '.env.local\n'
    printf '.env.*.local\n'
    printf '.jira-config.yml\n'
    printf '.skills\n'
    printf '.agent-skills.lock\n'
    printf '.cache/\n'
    printf '%s\n' "${GITIGNORE_END_MARKER}"
  } > "${block_file}"

  if [[ ! -f "${gitignore_file}" ]]; then
    if [[ -d "${workspace_root}/.git" ]]; then
      cp "${block_file}" "${gitignore_file}"
      rm -f "${block_file}"
      printf 'created'
      return 0
    fi
    rm -f "${block_file}"
    printf 'skipped'
    return 0
  fi

  local temp_file
  temp_file="$(mktemp)"
  awk -v start="${GITIGNORE_START_MARKER}" -v end="${GITIGNORE_END_MARKER}" -v block="${block_file}" '
    BEGIN { in_block = 0; replaced = 0 }
    $0 == start {
      if (!replaced) {
        while ((getline line < block) > 0) print line
        close(block)
        replaced = 1
      }
      in_block = 1
      next
    }
    in_block && $0 == end { in_block = 0; next }
    !in_block { print }
    END {
      if (!replaced) {
        print ""
        while ((getline line < block) > 0) print line
        close(block)
      }
    }
  ' "${gitignore_file}" > "${temp_file}"
  mv "${temp_file}" "${gitignore_file}"
  rm -f "${block_file}"
  printf 'updated'
}

# ------------------------------------------------------------------------------
# Skill-source resolution: lock file, ambiguity check, update handling.
#
# See docs/skill-source-resolution.md and docs/updates.md for the full
# specification. The lock file is written to <workspace>/.agent-skills.lock
# and is gitignored. It is advisory metadata for agents — `.agent-skills.yml`
# `skills.canonical_dir` still wins when both are present.
# ------------------------------------------------------------------------------
LOCK_FILE_NAME=".agent-skills.lock"

read_repo_version() {
  local version_file="${SCRIPT_DIR}/VERSION"
  if [[ -f "${version_file}" ]]; then
    head -n 1 "${version_file}" | tr -d '[:space:]'
  fi
}

read_repo_git_sha() {
  if command -v git >/dev/null 2>&1 && [[ -d "${SCRIPT_DIR}/.git" ]]; then
    (cd "${SCRIPT_DIR}" && git rev-parse --short=12 HEAD 2>/dev/null) || true
  fi
}

write_skills_lock() {
  local workspace_root="$1"
  local canonical_dir="$2"
  local lock_path="${workspace_root}/${LOCK_FILE_NAME}"
  local version
  local git_sha
  local timestamp
  version="$(read_repo_version)"
  git_sha="$(read_repo_git_sha)"
  timestamp="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  cat > "${lock_path}" <<EOF
{
  "schema": "agent-skills.lock/v1",
  "version": "${version}",
  "git_sha": "${git_sha}",
  "canonical_dir": "${canonical_dir}",
  "source_repo_dir": "${SCRIPT_DIR}",
  "installed_at": "${timestamp}",
  "installed_by": "setup.init ${version}"
}
EOF
  chmod 644 "${lock_path}" 2>/dev/null || true
}

# Detect more than one plausible skill source under the workspace and warn the
# operator. Called from --verify and at the end of first-run setup.
#
# Sources that resolve (after following symlinks) to the same directory are
# treated as one source — that is the expected `.skills -> agent-skills/skills`
# shape from `setup.init`, not real ambiguity.
check_skill_source_ambiguity() {
  local workspace_root="$1"
  local symlink="${workspace_root}/.skills"
  local vendored="${workspace_root}/.agent-skills/skills"
  local source_clone=""
  for candidate in "${workspace_root}"/agent-skills "${workspace_root}"/*/agent-skills; do
    if [[ -d "${candidate}/skills" ]]; then
      source_clone="${candidate}/skills"
      break
    fi
  done

  local raw_sources=()
  [[ -e "${symlink}" ]] && raw_sources+=("${symlink}")
  [[ -d "${vendored}" ]] && raw_sources+=("${vendored}")
  [[ -n "${source_clone}" ]] && raw_sources+=("${source_clone}")

  # Resolve each source to its real path and dedupe.
  local seen_resolved=""
  local distinct_sources=()
  local entry resolved
  for entry in "${raw_sources[@]}"; do
    if command -v python3 >/dev/null 2>&1; then
      resolved="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "${entry}")"
    else
      resolved="$(cd "${entry}" 2>/dev/null && pwd -P || printf '%s' "${entry}")"
    fi
    case "${seen_resolved}" in
      *"|${resolved}|"*) continue ;;
    esac
    seen_resolved="${seen_resolved}|${resolved}|"
    distinct_sources+=("${entry}")
  done

  if [[ "${#distinct_sources[@]}" -le 1 ]]; then
    return 0
  fi

  local configured_canonical=""
  if [[ -f "${workspace_root}/.agent-skills.yml" ]]; then
    configured_canonical="$(awk '
      /^skills:/ { in_block = 1; next }
      in_block && /^[^[:space:]]/ { in_block = 0 }
      in_block && /canonical_dir:/ {
        sub(/^[[:space:]]*canonical_dir:[[:space:]]*/, "")
        gsub(/^["'"'"']|["'"'"']$/, "")
        print
        exit
      }
    ' "${workspace_root}/.agent-skills.yml" 2>/dev/null)"
  fi

  if [[ -n "${configured_canonical}" ]]; then
    echo "  ok    skill-source canonical_dir configured: ${configured_canonical}"
    return 0
  fi

  echo "  WARN: multiple distinct skill sources discovered under ${workspace_root}:" >&2
  for entry in "${distinct_sources[@]}"; do
    echo "         - ${entry}" >&2
  done
  echo "         No skills.canonical_dir is configured. Set it in" >&2
  echo "         .agent-skills.yml to remove ambiguity." >&2
  echo "         See docs/skill-source-resolution.md." >&2
}

# Compare two semver strings. Echoes -1, 0, or 1 for a<b, a==b, a>b.
semver_cmp() {
  local a="${1#v}"
  local b="${2#v}"
  if [[ "${a}" == "${b}" ]]; then
    echo 0
    return 0
  fi
  local higher
  higher="$(printf '%s\n%s\n' "${a}" "${b}" | sort -V | tail -n 1)"
  if [[ "${higher}" == "${a}" ]]; then
    echo 1
  else
    echo -1
  fi
}

# Latest semver tag advertised by `origin` (or the configured remote). Empty if
# git or the network is unavailable.
latest_remote_release_tag() {
  local remote="${1:-origin}"
  command -v git >/dev/null 2>&1 || return 1
  (cd "${SCRIPT_DIR}" && git ls-remote --tags --refs "${remote}" 2>/dev/null) \
    | awk '{ print $2 }' \
    | sed 's#refs/tags/##' \
    | grep -E '^v?[0-9]+\.[0-9]+\.[0-9]+([-+][0-9A-Za-z.-]+)?$' \
    | sort -V \
    | tail -n 1
}

run_check_updates() {
  local local_version
  local remote_tag
  local remote_version
  local cmp
  local_version="$(read_repo_version)"
  if [[ -z "${local_version}" ]]; then
    echo "FAIL: cannot read VERSION from ${SCRIPT_DIR}/VERSION" >&2
    return 2
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "FAIL: git not installed; cannot check for updates" >&2
    return 2
  fi

  remote_tag="$(latest_remote_release_tag origin)"
  if [[ -z "${remote_tag}" ]]; then
    echo "FAIL: could not resolve latest tag from origin" >&2
    echo "      check network connectivity or fetch manually with: git fetch --tags" >&2
    return 2
  fi
  remote_version="${remote_tag#v}"

  cmp="$(semver_cmp "${local_version}" "${remote_version}")"
  echo "agent-skills update check"
  echo "  local : ${local_version}"
  echo "  latest: ${remote_version}  (tag: ${remote_tag})"
  case "${cmp}" in
    -1)
      echo "  status: update available"
      echo "  apply : ./setup.init --update     (or: git fetch --tags && git checkout ${remote_tag})"
      return 10
      ;;
    1)
      echo "  status: ahead of latest release (likely a contributor branch)"
      return 0
      ;;
    *)
      echo "  status: up to date"
      return 0
      ;;
  esac
}

run_self_update() {
  local workspace_root="$1"
  local target_ref="${UPDATE_REF}"
  local cmp_rc=0
  local local_version
  local remote_tag

  if ! command -v git >/dev/null 2>&1; then
    echo "FAIL: git not installed" >&2
    return 2
  fi
  if [[ ! -d "${SCRIPT_DIR}/.git" ]]; then
    echo "FAIL: ${SCRIPT_DIR} is not a git working tree; cannot self-update" >&2
    return 2
  fi
  if [[ -n "$(cd "${SCRIPT_DIR}" && git status --porcelain 2>/dev/null)" ]]; then
    echo "FAIL: working tree at ${SCRIPT_DIR} is dirty" >&2
    echo "      commit or stash local changes before running --update" >&2
    return 2
  fi

  echo "Fetching tags from origin..."
  (cd "${SCRIPT_DIR}" && git fetch --tags --quiet origin) \
    || { echo "FAIL: git fetch failed" >&2; return 2; }

  if [[ -z "${target_ref}" ]]; then
    target_ref="$(latest_remote_release_tag origin)"
    if [[ -z "${target_ref}" ]]; then
      echo "FAIL: could not resolve a latest release tag" >&2
      return 2
    fi
  fi

  local_version="$(read_repo_version)"
  remote_tag="${target_ref}"
  cmp_rc="$(semver_cmp "${local_version}" "${remote_tag#v}")"
  if [[ "${cmp_rc}" == "0" ]]; then
    echo "Already at ${target_ref}; refreshing workspace metadata."
  else
    echo "Checking out ${target_ref}..."
    (cd "${SCRIPT_DIR}" && git checkout --quiet "${target_ref}") \
      || { echo "FAIL: checkout ${target_ref} failed" >&2; return 2; }
  fi

  echo ""
  echo "Re-running setup.init non-interactively to refresh workspace metadata..."
  ASSUME_YES="true"
  CHECK_CONNECTIVITY="false"
  CHECK_CREDENTIAL_PROBE="false"
  JIRA_MODE="no"
  CONFLUENCE_MODE="no"
  SONAR_MODE="no"
  ENVIRONMENTS_MODE="no"
  UPDATE_MODE="false"
  CHECK_UPDATES_MODE="false"
  return 0
}

# ------------------------------------------------------------------------------
# Verify mode
# ------------------------------------------------------------------------------
count_managed_key_duplicates() {
  local env_file="$1"
  local key="$2"
  awk -v start="${START_MARKER}" -v stop="${END_MARKER}" -v key="${key}" '
    BEGIN { in_block = 0; total = 0 }
    {
      if ($0 == start) { in_block = 1; next }
      if ($0 == stop)  { in_block = 0; next }
      if (in_block) next
      if (match($0, "^[[:space:]]*(export[[:space:]]+)?" key "[[:space:]]*=")) {
        total++
      }
    }
    END { print total }
  ' "${env_file}"
}

verify_setup() {
  local workspace_root="$1"
  local env_file="${workspace_root}/.env"
  local skills_link="${workspace_root}/.skills"
  local errors=0

  echo "Verifying setup at ${workspace_root}"
  if [[ ! -f "${env_file}" ]]; then
    echo "  FAIL: ${env_file} not found. Run ./setup.init to create it." >&2
    return 1
  fi
  echo "  ok    .env present"

  # Check duplicate managed keys (any appearance outside the marker block).
  local key total
  for key in "${MANAGED_KEYS[@]}"; do
    total="$(count_managed_key_duplicates "${env_file}" "${key}")"
    if [[ "${total}" -gt 0 ]]; then
      echo "  FAIL: managed key ${key} appears ${total} time(s) OUTSIDE the marker block in ${env_file}" >&2
      errors=$((errors + 1))
    fi
  done
  [[ "${errors}" -eq 0 ]] && echo "  ok    no duplicate managed keys"

  set -a
  # shellcheck disable=SC1090
  source "${env_file}"
  set +a

  local var
  for var in WORKSPACE_ROOT ORG_NAME GITHUB_DEFAULT_BRANCH PROJECTS_JSON; do
    if [[ -z "${!var:-}" ]]; then
      echo "  FAIL: required variable ${var} is empty in .env" >&2
      errors=$((errors + 1))
    fi
  done

  if [[ "${WORKSPACE_ROOT:-}" != "${workspace_root}" ]]; then
    echo "  WARN: WORKSPACE_ROOT in .env (${WORKSPACE_ROOT:-}) does not match the directory being verified (${workspace_root})." >&2
  fi

  if validate_json_string "${PROJECTS_JSON:-}"; then
    echo "  ok    PROJECTS_JSON parses"
  else
    local rc=$?
    if [[ "${rc}" == "127" ]]; then
      echo "  WARN: cannot validate PROJECTS_JSON (no python3 or ruby found)" >&2
    else
      echo "  FAIL: PROJECTS_JSON is not valid JSON" >&2
      errors=$((errors + 1))
    fi
  fi

  if command -v python3 >/dev/null 2>&1; then
    local missing
    missing="$(AGENT_SKILLS_JSON="${PROJECTS_JSON}" AGENT_SKILLS_ROOT="${workspace_root}" python3 -c '
import json, os, sys
root = os.environ["AGENT_SKILLS_ROOT"]
projects = json.loads(os.environ["AGENT_SKILLS_JSON"])
missing = []
for p in projects:
    path = os.path.normpath(os.path.join(root, p.get("path", "")))
    if not os.path.isdir(path):
        missing.append("%s (%s)" % (p.get("name", "?"), path))
print("\n".join(missing))
' 2>/dev/null)"
    if [[ -n "${missing}" ]]; then
      echo "  WARN: PROJECTS_JSON entries point to missing directories:" >&2
      printf '         %s\n' ${missing} >&2
    else
      echo "  ok    every project path exists"
    fi
  fi

  if [[ -L "${skills_link}" ]]; then
    local target
    target="$(readlink "${skills_link}")"
    if [[ -d "${target}" ]]; then
      echo "  ok    .skills -> ${target}"
    else
      echo "  FAIL: .skills points at missing target ${target}" >&2
      errors=$((errors + 1))
    fi
  elif [[ -e "${skills_link}" ]]; then
    echo "  WARN: ${skills_link} exists but is not a symlink" >&2
  else
    echo "  WARN: ${skills_link} not present (rerun without --no-symlink)" >&2
  fi

  # Lock file (advisory; see docs/skill-source-resolution.md).
  local lock_path="${workspace_root}/${LOCK_FILE_NAME}"
  if [[ -f "${lock_path}" ]]; then
    local lock_version
    lock_version="$(awk -F'"' '/"version"/ { print $4; exit }' "${lock_path}")"
    local repo_version
    repo_version="$(read_repo_version)"
    if [[ -n "${lock_version}" && "${lock_version}" == "${repo_version}" ]]; then
      echo "  ok    .agent-skills.lock at v${lock_version}"
    else
      echo "  WARN: .agent-skills.lock pinned to v${lock_version:-unknown} but repo is at v${repo_version:-unknown}" >&2
      echo "         run ./setup.init --update or rerun ./setup.init to refresh" >&2
    fi
  else
    echo "  WARN: ${lock_path} not present (rerun ./setup.init to create it)" >&2
  fi

  # URL / project-key shape checks (do not echo secrets).
  if [[ -n "${JIRA_HOST:-}" ]] && ! validate_url "${JIRA_HOST}" >/dev/null 2>&1; then
    echo "  WARN: JIRA_HOST does not look like a URL" >&2
  fi
  if [[ -n "${CONFLUENCE_HOST:-}" ]] && ! validate_url "${CONFLUENCE_HOST}" >/dev/null 2>&1; then
    echo "  WARN: CONFLUENCE_HOST does not look like a URL" >&2
  fi
  if [[ -n "${JIRA_PROJECT_KEYS:-}" ]] && ! validate_project_keys "${JIRA_PROJECT_KEYS}" >/dev/null 2>&1; then
    echo "  WARN: JIRA_PROJECT_KEYS does not look like comma-separated project keys" >&2
  fi

  if [[ -n "${JIRA_HOST:-}" ]]; then
    if [[ -z "${JIRA_API_TOKEN:-}" ]]; then
      echo "  WARN: JIRA_HOST set but JIRA_API_TOKEN is empty" >&2
    else
      echo "  ok    Jira credentials present"
    fi
  fi
  if [[ -n "${CONFLUENCE_HOST:-}" ]]; then
    if [[ -z "${CONFLUENCE_API_TOKEN:-}" ]]; then
      echo "  WARN: CONFLUENCE_HOST set but CONFLUENCE_API_TOKEN is empty" >&2
    else
      echo "  ok    Confluence credentials present"
    fi
  fi

  if [[ -n "${SONAR_HOST_URL:-}" ]] && ! validate_url "${SONAR_HOST_URL}" >/dev/null 2>&1; then
    echo "  WARN: SONAR_HOST_URL does not look like a URL" >&2
  fi
  if [[ -n "${SONAR_HOST_URL:-}" ]]; then
    if [[ -z "${SONAR_TOKEN:-}" ]]; then
      echo "  WARN: SONAR_HOST_URL set but SONAR_TOKEN is empty" >&2
    else
      echo "  ok    Sonar credentials present"
    fi
  fi

  if [[ -n "${ENVIRONMENTS_JSON:-}" ]]; then
    if validate_json_string "${ENVIRONMENTS_JSON}" >/dev/null 2>&1; then
      echo "  ok    ENVIRONMENTS_JSON parses"
    else
      local rc=$?
      if [[ "${rc}" != "127" ]]; then
        echo "  FAIL: ENVIRONMENTS_JSON is not valid JSON" >&2
        errors=$((errors + 1))
      fi
    fi
  fi

  # Run the same warn-only blast-radius probe used at first run, so
  # `--verify` periodically resurfaces the warning if the operator added a
  # destructive credential to their shell or .env after setup.
  ENV_FILE="${env_file}" check_credential_blast_radius

  # Skill-source resolution check (see docs/skill-source-resolution.md).
  check_skill_source_ambiguity "${workspace_root}"

  if [[ "${errors}" -gt 0 ]]; then
    echo "" >&2
    echo "Verification failed with ${errors} error(s)." >&2
    return 1
  fi
  echo ""
  echo "Verification passed."
}

# ==============================================================================
# Main
# ==============================================================================

# --check-updates is workspace-independent. Handle it before any prompting.
if [[ "${CHECK_UPDATES_MODE}" == "true" ]]; then
  run_check_updates
  exit $?
fi

# --update first switches the source clone to the latest tag, then falls
# through into a normal non-interactive setup run that refreshes .skills and
# the lock file.
if [[ "${UPDATE_MODE}" == "true" ]]; then
  if [[ -z "${WORKSPACE_ROOT}" ]]; then
    WORKSPACE_ROOT="${DEFAULT_WORKSPACE_ROOT}"
  fi
  mkdir -p "${WORKSPACE_ROOT}"
  WORKSPACE_ROOT="$(cd "${WORKSPACE_ROOT}" && pwd)"
  run_self_update "${WORKSPACE_ROOT}" || exit $?
fi

if [[ -z "${WORKSPACE_ROOT}" ]]; then
  if [[ "${VERIFY_MODE}" == "true" ]]; then
    WORKSPACE_ROOT="${DEFAULT_WORKSPACE_ROOT}"
  else
    WORKSPACE_ROOT="$(prompt "Workspace root" "${DEFAULT_WORKSPACE_ROOT}" \
      "Parent folder of your agent-skills clone and any sibling repos it
should manage. Example: /path/to/work contains agent-skills/, repo-a/, and
repo-b/. setup.init will write .env, .jira-config.yml, .skills, and a
.gitignore block in that parent folder.")"
  fi
fi

mkdir -p "${WORKSPACE_ROOT}"
WORKSPACE_ROOT="$(cd "${WORKSPACE_ROOT}" && pwd)"

if [[ "${VERIFY_MODE}" == "true" ]]; then
  verify_setup "${WORKSPACE_ROOT}"
  exit $?
fi

guard_workspace_root "${WORKSPACE_ROOT}" "${WORKSPACE_ROOT_EXPLICIT}"

ENV_FILE="${WORKSPACE_ROOT}/.env"
JIRA_FILE="${WORKSPACE_ROOT}/.jira-config.yml"
SKILLS_LINK="${WORKSPACE_ROOT}/.skills"

# Pre-detect GitHub org so we can offer a richer ORG_NAME default.
DEFAULT_GITHUB_ORG=""
if DEFAULT_GITHUB_ORG="$(detect_github_org_from_siblings "${WORKSPACE_ROOT}" 2>/dev/null)"; then
  :
elif command -v gh >/dev/null 2>&1; then
  DEFAULT_GITHUB_ORG="$(gh api user --jq .login 2>/dev/null || true)"
fi

# Decide on Jira/Confluence first so we can chain inferences.
if [[ "${JIRA_MODE}" == "yes" ]]; then
  USE_JIRA="yes"
elif [[ "${JIRA_MODE}" == "no" ]]; then
  USE_JIRA="no"
elif confirm "Configure Jira for issue-aware work" "no"; then
  USE_JIRA="yes"
else
  USE_JIRA="no"
fi

JIRA_HOST=""
JIRA_AUTH_TYPE="bearer"
JIRA_LOGIN=""
JIRA_API_TOKEN=""
JIRA_PROJECT_KEYS=""

if [[ "${USE_JIRA}" == "yes" ]]; then
  echo "" >&2
  echo "Jira setup. Values are written to ${ENV_FILE} which is gitignored." >&2

  JIRA_HOST="$(prompt "Jira host URL" "" \
"REQUIRED for Jira. Full URL with scheme.
EXAMPLES:
  https://acme.atlassian.net   (Atlassian Cloud)
  https://jira.acme.example.com (self-hosted)" \
    validate_url)"

  JIRA_AUTH_TYPE="$(prompt "Jira auth type (bearer | basic)" "bearer" \
"OPTIONAL. 'bearer' for API tokens / PATs, 'basic' for email + token.")"

  local_login_help="OPTIONAL for bearer; REQUIRED for basic.
EXAMPLE: person@acme.example.com"
  JIRA_LOGIN="$(prompt "Jira login / email" "" "${local_login_help}" validate_email_or_blank)"

  # Suggest a project key derived from a ticket if the user pastes one.
  jira_keys_help="REQUIRED for Jira. Comma-separated project keys (the prefix in ticket IDs).
EXAMPLE: ABC,PLAT,KVB  -> recognises ABC-123, PLAT-9, KVB-42.
This is NOT the API token. Tip: paste a ticket key (e.g. ABC-123) or ticket URL
and setup.init will pick the project key for you."
  raw_keys="$(prompt "Jira project keys" "" "${jira_keys_help}")"
  if inferred_key="$(extract_project_key_from_ticket "${raw_keys}")"; then
    if is_interactive; then
      echo "    Detected project key '${inferred_key}' from ticket input." >&2
    fi
    raw_keys="${inferred_key}"
  fi
  # Re-validate; in non-interactive mode we accept whatever default came in.
  if validate_project_keys "${raw_keys}" >/dev/null 2>&1; then
    JIRA_PROJECT_KEYS="${raw_keys}"
  else
    JIRA_PROJECT_KEYS="${raw_keys}"
    if is_interactive; then
      echo "    Storing the value as-is. Re-run setup.init to fix." >&2
    fi
  fi

  echo "" >&2
  echo "    Jira API token / PAT. Generate one at your Jira instance's" >&2
  echo "    'Personal Access Tokens' or 'API tokens' page." >&2
  echo "    The token is stored ONLY in ${ENV_FILE} (gitignored)." >&2
  JIRA_API_TOKEN="$(prompt_secret "Jira API token (leave blank to skip)" "")"
fi

# Confluence
if [[ "${CONFLUENCE_MODE}" == "yes" ]]; then
  USE_CONF="yes"
elif [[ "${CONFLUENCE_MODE}" == "no" ]]; then
  USE_CONF="no"
elif [[ "${USE_JIRA}" == "yes" ]] && confirm "Also configure Confluence (often paired with Jira)" "no"; then
  USE_CONF="yes"
elif [[ "${USE_JIRA}" != "yes" ]] && confirm "Configure Confluence for docs-aware work" "no"; then
  USE_CONF="yes"
else
  USE_CONF="no"
fi

CONF_HOST=""
CONF_LOGIN=""
CONF_TOKEN=""
CONF_SPACES=""

if [[ "${USE_CONF}" == "yes" ]]; then
  echo "" >&2
  echo "Confluence setup. Values are written to ${ENV_FILE} which is gitignored." >&2

  default_conf_host=""
  if [[ -n "${JIRA_HOST}" ]]; then
    default_conf_host="$(infer_confluence_from_jira "${JIRA_HOST}" || true)"
    if [[ -n "${default_conf_host}" ]] && is_interactive; then
      echo "    Inferred Confluence host from Jira host." >&2
    fi
  fi
  CONF_HOST="$(prompt "Confluence host URL" "${default_conf_host}" \
"OPTIONAL. Full URL with scheme.
EXAMPLES:
  https://acme.atlassian.net/wiki  (Atlassian Cloud)
  https://confluence.acme.example.com (self-hosted)" \
    validate_url)"

  CONF_LOGIN="$(prompt "Confluence login / email" "${JIRA_LOGIN}" \
"OPTIONAL. Usually the same email as Jira on Atlassian Cloud." validate_email_or_blank)"

  echo "" >&2
  echo "    Confluence API token. Stored ONLY in ${ENV_FILE} (gitignored)." >&2
  CONF_TOKEN="$(prompt_secret "Confluence API token (leave blank to skip)" "")"

  CONF_SPACES="$(prompt "Confluence space keys (comma-separated, optional)" "" \
"OPTIONAL. Spaces the agent may consult.
EXAMPLE: ENG,ARCH,RUN")"
fi

# Sonar (optional)
if [[ "${SONAR_MODE}" == "yes" ]]; then
  USE_SONAR="yes"
elif [[ "${SONAR_MODE}" == "no" ]]; then
  USE_SONAR="no"
elif confirm "Configure SonarQube / SonarCloud (optional, only if your CI publishes a Sonar report)" "no"; then
  USE_SONAR="yes"
else
  USE_SONAR="no"
fi

SONAR_HOST_URL_VAL=""
SONAR_TOKEN_VAL=""
if [[ "${USE_SONAR}" == "yes" ]]; then
  echo "" >&2
  echo "SonarQube setup. Values are written to ${ENV_FILE} which is gitignored." >&2

  SONAR_HOST_URL_VAL="$(prompt "Sonar host URL" "" \
"OPTIONAL. Full URL with scheme.
EXAMPLES:
  https://sonarcloud.io        (SonarCloud)
  https://sonar.example.com    (self-hosted SonarQube)" \
    validate_url)"

  echo "" >&2
  echo "    Sonar user token. Stored ONLY in ${ENV_FILE} (gitignored)." >&2
  SONAR_TOKEN_VAL="$(prompt_secret "Sonar user token (leave blank to skip)" "")"
fi

# Environment access pointers (optional)
if [[ "${ENVIRONMENTS_MODE}" == "yes" ]]; then
  USE_ENVS="yes"
elif [[ "${ENVIRONMENTS_MODE}" == "no" ]]; then
  USE_ENVS="no"
elif confirm "Configure deployed-environment pointers for read-only investigation (recommended for production teams)" "no"; then
  USE_ENVS="yes"
else
  USE_ENVS="no"
fi

ENVIRONMENTS_JSON_VAL='[]'
if [[ "${USE_ENVS}" == "yes" ]]; then
  echo "" >&2
  echo "Environment-access setup." >&2
  echo "  This stores POINTERS ONLY (env name, host, log paths, kubectl context)." >&2
  echo "  Never put SSH private keys, passwords, or production credentials here." >&2
  echo "  The investigator skill enforces read-only discipline (see SKILL.md)." >&2
  echo "" >&2

  envs_first=1
  ENVIRONMENTS_JSON_VAL='['
  while :; do
    if [[ "${envs_first}" -eq 1 ]]; then
      env_prompt="First environment name (e.g. qa, staging, prod-eu)"
    else
      env_prompt="Add another environment name (blank to finish)"
    fi
    env_name="$(prompt "${env_prompt}" "")"
    [[ -z "${env_name}" ]] && break

    env_type="$(prompt "  Type for ${env_name} (test|qa|staging|prod|other)" "qa" \
"REQUIRED. Used by the investigator to apply prod-only guardrails.")"

    env_access="$(prompt "  Access method (ssh|kubectl|log-aggregator|cloud-console|none)" "none" \
"REQUIRED. 'none' means the agent will only describe what to look for.")"

    env_ssh="" env_kctx="" env_ns="" env_logs="" env_logagg="" env_notes=""
    case "${env_access}" in
      ssh)
        env_ssh="$(prompt "  SSH target (user@host or ~/.ssh/config alias)" "" \
"OPTIONAL. Leave blank if you prefer to type it yourself each time.")"
        env_logs="$(prompt "  Typical log paths (comma-separated)" "/var/log/app/*.log" \
"OPTIONAL. Examples: /var/log/app/*.log, /var/log/syslog")"
        ;;
      kubectl)
        env_kctx="$(prompt "  kubectl context name" "" \
"OPTIONAL. The context as listed by 'kubectl config get-contexts'.")"
        env_ns="$(prompt "  Default namespace" "default" \
"OPTIONAL. The namespace the agent should default to.")"
        ;;
      log-aggregator)
        env_logagg="$(prompt "  Log aggregator URL" "" \
"OPTIONAL. URL to Splunk/ELK/Datadog/CloudWatch where logs live." validate_url)"
        ;;
    esac

    env_notes="$(prompt "  Notes for the investigator (RBAC, jump host, approval rules)" "" \
"OPTIONAL. The investigator reads this verbatim before suggesting commands.")"

    [[ "${envs_first}" -eq 0 ]] && ENVIRONMENTS_JSON_VAL+=","
    ENVIRONMENTS_JSON_VAL+="$(printf '{"name":"%s","type":"%s","access":"%s","ssh_target":"%s","kubectl_context":"%s","namespace":"%s","log_paths":"%s","log_aggregator":"%s","notes":"%s"}' \
      "$(json_escape "${env_name}")" \
      "$(json_escape "${env_type}")" \
      "$(json_escape "${env_access}")" \
      "$(json_escape "${env_ssh}")" \
      "$(json_escape "${env_kctx}")" \
      "$(json_escape "${env_ns}")" \
      "$(json_escape "${env_logs}")" \
      "$(json_escape "${env_logagg}")" \
      "$(json_escape "${env_notes}")")"
    envs_first=0

    is_interactive || break
  done
  ENVIRONMENTS_JSON_VAL+=']'

  if ! validate_json_string "${ENVIRONMENTS_JSON_VAL}"; then
    rc=$?
    if [[ "${rc}" != "127" ]]; then
      echo "Internal error: generated ENVIRONMENTS_JSON is not valid JSON. Resetting to []." >&2
      ENVIRONMENTS_JSON_VAL='[]'
    fi
  fi
fi

# Optional non-blocking connectivity probe.
if [[ "${USE_JIRA}" == "yes" || "${USE_CONF}" == "yes" || "${USE_SONAR}" == "yes" ]]; then
  echo ""
  echo "Connectivity check (warn-only; --no-connectivity-check to skip):"
  [[ "${USE_JIRA}" == "yes" ]] && check_url_reachable "Jira host"      "${JIRA_HOST}"
  [[ "${USE_CONF}" == "yes" ]] && check_url_reachable "Confluence host" "${CONF_HOST}"
  [[ "${USE_SONAR}" == "yes" ]] && check_url_reachable "Sonar host"    "${SONAR_HOST_URL_VAL}"
fi

# Now derive defaults that depend on Jira/Confluence answers.
DEFAULT_ORG_NAME=""
if [[ -n "${JIRA_HOST}" ]]; then
  DEFAULT_ORG_NAME="$(prettify_slug "$(infer_org_from_jira_host "${JIRA_HOST}")")"
elif [[ -n "${CONF_HOST}" ]]; then
  DEFAULT_ORG_NAME="$(prettify_slug "$(infer_org_from_jira_host "${CONF_HOST}")")"
elif [[ -n "${DEFAULT_GITHUB_ORG}" ]]; then
  DEFAULT_ORG_NAME="$(prettify_slug "${DEFAULT_GITHUB_ORG}")"
else
  DEFAULT_ORG_NAME="$(basename "${WORKSPACE_ROOT}")"
  [[ -z "${DEFAULT_ORG_NAME}" || "${DEFAULT_ORG_NAME}" == "/" ]] && DEFAULT_ORG_NAME="Local Workspace"
fi

ORG_NAME="$(prompt "Display name for this workspace" "${DEFAULT_ORG_NAME}" \
"REQUIRED. Used in summaries, PR descriptions, and stakeholder output.
EXAMPLES: 'Acme Platform', 'Open Banking Team', 'Local Workspace'." \
  validate_org_name)"

DEFAULT_ORG_DOMAIN="$(infer_org_domain "${JIRA_LOGIN}" "${DEFAULT_GITHUB_ORG}" "${JIRA_HOST}")"
ORG_DOMAIN="$(prompt "Org email/identity domain" "${DEFAULT_ORG_DOMAIN}" \
"OPTIONAL. Used when generating PR / release-note text.
EXAMPLE: acme.example.com. Use 'localhost' for purely local dry runs.")"

GITHUB_ORG="$(prompt "GitHub owner/user for repos" "${DEFAULT_GITHUB_ORG}" \
"OPTIONAL. Required only for clone, push, or PR work.
EXAMPLE: acme-eng. Leave blank for offline / read-only planning.")"

GITHUB_DEFAULT_BRANCH="$(prompt "Default base branch" "main" \
"REQUIRED. Default base branch for new feature work.
COMMON VALUES: main, master, develop, trunk." validate_branch_name)"

PROJECTS_JSON="$(detect_projects_json "${WORKSPACE_ROOT}" "${GITHUB_DEFAULT_BRANCH}")"
DETECTED_COUNT="$(count_detected_projects "${WORKSPACE_ROOT}")"

if ! validate_json_string "${PROJECTS_JSON}"; then
  rc=$?
  if [[ "${rc}" != "127" ]]; then
    echo "Internal error: generated PROJECTS_JSON is not valid JSON. Aborting." >&2
    echo "${PROJECTS_JSON}" >&2
    exit 1
  fi
fi

ENV_CREATED="false"
if [[ ! -f "${ENV_FILE}" ]]; then
  cp "${SCRIPT_DIR}/.env.example" "${ENV_FILE}"
  ENV_CREATED="true"
  echo "Created ${ENV_FILE}"
else
  echo "Updating generated setup block in ${ENV_FILE}"
fi

# Restrict permissions on .env (it may carry secrets).
chmod 600 "${ENV_FILE}" 2>/dev/null || true

write_env_block \
  "${ENV_FILE}" \
  "${WORKSPACE_ROOT}" \
  "${ORG_NAME}" \
  "${ORG_DOMAIN}" \
  "${GITHUB_ORG}" \
  "${GITHUB_DEFAULT_BRANCH}" \
  "${USE_JIRA}" \
  "${JIRA_HOST}" \
  "${JIRA_AUTH_TYPE}" \
  "${JIRA_LOGIN}" \
  "${JIRA_API_TOKEN}" \
  "${JIRA_PROJECT_KEYS}" \
  "${USE_CONF}" \
  "${CONF_HOST}" \
  "${CONF_LOGIN}" \
  "${CONF_TOKEN}" \
  "${CONF_SPACES}" \
  "${PROJECTS_JSON}" \
  "${USE_SONAR}" \
  "${SONAR_HOST_URL_VAL}" \
  "${SONAR_TOKEN_VAL}" \
  "${ENVIRONMENTS_JSON_VAL}"

JIRA_CREATED="false"
if [[ "${USE_JIRA}" == "yes" ]]; then
  if [[ ! -f "${JIRA_FILE}" ]]; then
    cp "${SCRIPT_DIR}/.jira-config.example.yml" "${JIRA_FILE}"
    JIRA_CREATED="true"
    echo "Created ${JIRA_FILE}"
  else
    echo "Keeping existing ${JIRA_FILE}"
  fi
  chmod 600 "${JIRA_FILE}" 2>/dev/null || true
  update_jira_project_key "${JIRA_FILE}" "${JIRA_PROJECT_KEYS}"
fi

SYMLINK_STATUS="skipped"
if [[ "${SYMLINK_MODE}" != "no" ]]; then
  if [[ -L "${SKILLS_LINK}" ]]; then
    SYMLINK_STATUS="kept"
    echo "Keeping existing ${SKILLS_LINK} symlink"
  elif [[ -e "${SKILLS_LINK}" ]]; then
    SYMLINK_STATUS="conflict"
    echo "Skipped ${SKILLS_LINK}: path already exists and is not a symlink"
  else
    ln -s "${SCRIPT_DIR}/skills" "${SKILLS_LINK}"
    SYMLINK_STATUS="created"
    echo "Created ${SKILLS_LINK} -> ${SCRIPT_DIR}/skills"
  fi
fi

GITIGNORE_STATUS="$(update_workspace_gitignore "${WORKSPACE_ROOT}")"
case "${GITIGNORE_STATUS}" in
  created) echo "Created ${WORKSPACE_ROOT}/.gitignore with agent-skills entries" ;;
  updated) echo "Refreshed agent-skills block in ${WORKSPACE_ROOT}/.gitignore" ;;
  skipped) : ;;
esac

# Validate the produced .env can be sourced and PROJECTS_JSON parses.
set -a
# shellcheck disable=SC1090
source "${ENV_FILE}"
set +a
if validate_json_string "${PROJECTS_JSON:-}"; then
  echo "Validated ${ENV_FILE}"
else
  rc=$?
  if [[ "${rc}" == "127" ]]; then
    echo "Skipped JSON validation: neither python3 nor ruby is installed."
  else
    echo "Warning: PROJECTS_JSON in ${ENV_FILE} did not parse after write." >&2
    exit 1
  fi
fi

# Final duplicate-key sanity check.
DUP_FOUND=0
for k in "${MANAGED_KEYS[@]}"; do
  c="$(count_managed_key_duplicates "${ENV_FILE}" "${k}")"
  if [[ "${c}" -gt 0 ]]; then
    echo "Warning: ${k} appears ${c} time(s) outside the marker block in ${ENV_FILE}" >&2
    DUP_FOUND=1
  fi
done
if [[ "${DUP_FOUND}" -eq 1 ]]; then
  echo "Run ./setup.init --verify for details." >&2
fi

check_credential_blast_radius

# Write the skill-source lock file. Canonical_dir defaults to the .skills
# symlink in local-workspace mode; falls back to the source repo when the
# symlink was skipped. See docs/skill-source-resolution.md.
LOCK_CANONICAL_DIR="${SKILLS_LINK}"
if [[ ! -e "${SKILLS_LINK}" ]]; then
  LOCK_CANONICAL_DIR="${SCRIPT_DIR}/skills"
fi
write_skills_lock "${WORKSPACE_ROOT}" "${LOCK_CANONICAL_DIR}"
echo "Wrote ${WORKSPACE_ROOT}/${LOCK_FILE_NAME}"

# Surface a warning if the operator has more than one plausible skill source
# without an explicit canonical_dir in `.agent-skills.yml`.
check_skill_source_ambiguity "${WORKSPACE_ROOT}" || true

cat <<EOF

----------------------------------------
Setup complete.
----------------------------------------
Workspace root : ${WORKSPACE_ROOT}
.env           : ${ENV_FILE} ($([[ "${ENV_CREATED}" == "true" ]] && echo "created" || echo "updated"))
Detected repos : ${DETECTED_COUNT} (under ${WORKSPACE_ROOT})
.skills        : ${SYMLINK_STATUS}
.skills-lock   : ${WORKSPACE_ROOT}/${LOCK_FILE_NAME}
.gitignore     : ${GITIGNORE_STATUS}
Jira           : $([[ "${USE_JIRA}" == "yes" ]] && echo "configured (${JIRA_FILE})" || echo "skipped")
Confluence     : $([[ "${USE_CONF}" == "yes" ]] && echo "configured" || echo "skipped")
Sonar          : $([[ "${USE_SONAR}" == "yes" ]] && echo "configured" || echo "skipped")
Environments   : $([[ "${USE_ENVS}" == "yes" ]] && echo "configured (read-only pointers only)" || echo "skipped")

Next steps:
1. Open ${ENV_FILE} once and confirm build/format/Jira values look correct.
2. Tell your AI assistant where the skills live (see README "Using With Your AI Assistant").
3. Try a starter prompt from ${SCRIPT_DIR}/README.md.
4. To re-check this setup later, run: ./setup.init --verify
5. To check for new releases later, run: ./setup.init --check-updates
EOF
